{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxl-classroom.github.io/schemas/observation.schema.json",
  "title": "Observation",
  "description": "A point-in-time observation of a student repository's state, stored in observations/<assignment-id>/<login>/<timestamp>.json. Two variants: a default-branch snapshot (the legacy shape) or a tagged-submission record produced when collect/ finds a refs/tags/submit/* tag on the student repo.",
  "type": "object",
  "oneOf": [
    {
      "title": "Snapshot observation (default-branch tip).",
      "type": "object",
      "required": [
        "schema_version",
        "assignment_id",
        "github_login",
        "repo_id",
        "observed_at",
        "ref",
        "sha",
        "collection_type"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "snapshot" },
        "assignment_id": { "type": "string", "minLength": 1 },
        "github_login": { "type": "string", "minLength": 1 },
        "repo_id": { "type": "integer" },
        "observed_at": { "type": "string", "format": "date-time" },
        "ref": { "type": "string", "minLength": 1 },
        "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "observer_run": { "type": "string", "format": "uri" },
        "collection_type": {
          "type": "string",
          "enum": ["scheduled", "manual", "deadline", "lockdown", "preservation"]
        }
      }
    },
    {
      "title": "Tagged-submission observation (latest refs/tags/submit/* tag).",
      "type": "object",
      "required": [
        "schema_version",
        "type",
        "assignment_id",
        "github_login",
        "repo_id",
        "observed_at",
        "tag",
        "declared_at",
        "tagged_sha"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "type": { "type": "string", "const": "tagged-submission" },
        "assignment_id": { "type": "string", "minLength": 1 },
        "github_login": { "type": "string", "minLength": 1 },
        "repo_id": { "type": "integer" },
        "observed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side time at which collect/ saw the tag. Authoritative."
        },
        "tag": {
          "type": "string",
          "pattern": "^submit/[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z-[0-9a-f]{7,40}$",
          "description": "Full tag name in the submit/<ISO-8601-Z>-<short-sha> format."
        },
        "declared_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp parsed from the tag name. Student-declared, observed-not-authoritative."
        },
        "tagged_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Full SHA of the commit the tag points at."
        },
        "observer_run": { "type": "string", "format": "uri" }
      }
    }
  ]
}
