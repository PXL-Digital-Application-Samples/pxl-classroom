{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxl-classroom.github.io/schemas/observation.schema.json",
  "title": "Observation",
  "description": "A point-in-time observation of a student repository's state, stored in observations/<assignment-id>/<login>/<timestamp>.json.",
  "type": "object",
  "required": [
    "schema_version",
    "assignment_id",
    "github_login",
    "repo_id",
    "observed_at",
    "ref",
    "sha",
    "collection_type"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for forward compatibility."
    },
    "assignment_id": {
      "type": "string",
      "minLength": 1,
      "description": "ID of the assignment being observed."
    },
    "github_login": {
      "type": "string",
      "minLength": 1,
      "description": "GitHub username of the student."
    },
    "repo_id": {
      "type": "integer",
      "description": "GitHub repository ID of the observed repository."
    },
    "observed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the observation."
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "description": "Git ref that was observed (e.g. refs/heads/main)."
    },
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "description": "Full 40-character hex SHA of the commit at the observed ref."
    },
    "observer_run": {
      "type": "string",
      "format": "uri",
      "description": "URL of the workflow run that collected this observation."
    },
    "collection_type": {
      "type": "string",
      "enum": ["scheduled", "manual", "deadline", "lockdown"],
      "description": "How this observation was triggered."
    }
  }
}
