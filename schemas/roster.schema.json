{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxl-classroom.github.io/schemas/roster.schema.json",
  "title": "Roster",
  "description": "Student roster stored in students/roster.yml within a PXL Classroom control repository.",
  "type": "object",
  "required": ["schema_version", "students"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for forward compatibility."
    },
    "students": {
      "type": "array",
      "description": "List of enrolled students.",
      "items": {
        "type": "object",
        "required": ["student_id", "display_name"],
        "additionalProperties": false,
        "properties": {
          "student_id": {
            "type": "string",
            "minLength": 1,
            "description": "Institutional student identifier (e.g. r-number)."
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable name for display purposes."
          },
          "class_group": {
            "type": "string",
            "description": "Optional class group or section the student belongs to."
          },
          "github_login": {
            "type": ["string", "null"],
            "description": "GitHub username. Null if not yet linked."
          },
          "github_id": {
            "type": ["integer", "null"],
            "description": "Immutable GitHub user ID. Null if not yet linked."
          },
          "active": {
            "type": "boolean",
            "default": true,
            "description": "Whether the student is actively enrolled."
          }
        }
      }
    }
  }
}
